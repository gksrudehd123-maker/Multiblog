# Database (Supabase Postgres)
DATABASE_URL="postgresql://user:password@host:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Anthropic Claude API
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-opus-4-6"

# Google OAuth (Blogger API — Blogspot access token refresh)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Chrome Extension Webhook Auth (확장프로그램이 서버로 포스팅 전송 시 사용)
WEBHOOK_SECRET=""

# Next.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# imgbb — Blogspot 이미지 호스팅 (Blogger API에 업로드 엔드포인트 없음)
# https://api.imgbb.com/ 에서 무료 API 키 발급
IMGBB_API_KEY=""
